generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Alert {
  id           String   @id @default(uuid()) 
  qrCodeId     String
  reportedById String?
  reporterName String?
  contactInfo  String?
  gpsLat       Float?
  gpsLng       Float?
  photoUrl     String?
  description  String?
  status       String   @default("new")    
  createdAt    DateTime @default(now())
  QrCode       QrCode   @relation(fields: [qrCodeId], references: [id])
  reportedBy   User?    @relation("ReportedAlerts", fields: [reportedById], references: [id], onDelete: SetNull)

  @@index([reportedById, createdAt])
}

model QrCode {
  id             String    @id @default(uuid())
  token          String    @unique
  label          String?
  destinationUrl String
  status         String    @default("active")
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  createdById    String?
  createdBy      User?     @relation(fields: [createdById], references: [id])
  Alert          Alert[]
  ScanLog        ScanLog[]
}

model ScanLog {
  id        String   @id @default(uuid()) 
  qrCodeId  String?
  userId    String?
  scannedAt DateTime @default(now())
  ipAddress String?
  userAgent String?
  gpsLat    Float?
  gpsLng    Float?
  result    String
  QrCode    QrCode?  @relation(fields: [qrCodeId], references: [id])
  user      User?    @relation("UserScanLogs", fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, scannedAt])
}

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  passwordHash        String?
  fullName            String?
  phoneNumber         String?
  role                String    @default("user")
  authVersion         Int       @default(0)
  resetToken          String?
  resetTokenExpiresAt DateTime?
  lastLogin           DateTime?
  createdAt           DateTime  @default(now())
  QrCode              QrCode[]
  ScanLog             ScanLog[] @relation("UserScanLogs")
  reportedAlerts      Alert[]   @relation("ReportedAlerts")
}

model ActivityLog {
  id        String   @id @default(uuid())
  qrCodeId  String?
  type      String
  message   String
  status    String?
  createdAt DateTime @default(now())
}
