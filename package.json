{
  "name": "vafpqr-secure-qr-system",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "backend",
    "landing-web",
    "admin-web",
    "mobile-app"
  ],
  "scripts": {
    "start:backend": "npm --workspace backend start",
    "dev:admin": "npm --workspace admin-web run dev",
    "dev:landing": "npm --workspace landing-web run dev",
    "start:mobile": "npm --workspace mobile-app run start",
    "build:admin": "npm --workspace admin-web run build",
    "build:landing": "npm --workspace landing-web run build",
    "build:web": "npm run build:landing && npm run build:admin"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
